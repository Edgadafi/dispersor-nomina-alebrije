# SDP URLs (necesitan 2+ partes de dominio para crear tenants)
# Para localhost usa app.localhost / api.localhost (resuelven a 127.0.0.1)
BASE_URL=http://api.localhost:8000
SDP_UI_BASE_URL=http://app.localhost:3000

# Genera estas dos con la Stellar Lab o con el CLI
DISTRIBUTION_PUBLIC_KEY=G...
DISTRIBUTION_SEED=S...

# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SEP10_SIGNING_PUBLIC_KEY=G...   # genera con stellar keygen
SEP10_SIGNING_PRIVATE_KEY=S...
SEP24_JWT_SECRET=string_aleatorio_64_chars
DISTRIBUTION_ACCOUNT_ENCRYPTION_PASSPHRASE=otra_frase_larga
CHANNEL_ACCOUNT_ENCRYPTION_PASSPHRASE=otra_frase_larga_distinta

# CETES: Etherfuse testnet (opcional, ya es el default)
# CETES_ISSUER=GC3CW7EDYRTWQ635VDIGY6S4ZUF5L6TQ7AA4MWS7LEQDBLUSZXV7UPS4

# Para el hackathon puedes dejar estas vacías si aún no tienes credenciales
# El SDP arranca sin ellas en modo dev pero no mandará SMS reales
# Recibos de nómina (dispersor): DRY_RUN por defecto. Para SMS reales: RECEIPT_DRY_RUN=0 y configura Twilio
RECEIPT_DRY_RUN=true
# usa TWILIO_SERVICE_SID o TWILIO_PHONE_NUMBER

# LFPDP: commitment on-chain + datos off-chain. PAYROLL_STORE_KEY (min 32 chars) para cifrado.
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYROLL_STORE_KEY=
# AUDITOR_TOKEN= (opcional, para GET /api/batch/:id)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SERVICE_SID=
TWILIO_PHONE_NUMBER=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_SENDER_ID=
